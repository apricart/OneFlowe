table audit_logs {
  id serial [pk, not null, increment]
  user_id uuid
  organization_id integer
  branch_id integer
  action varchar(128) [not null]
  entity varchar(128) [not null]
  entity_id varchar(128)
  metadata jsonb
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    user_id [name: 'audit_user_idx']
    entity [name: 'audit_entity_idx']
    organization_id [name: 'audit_org_idx']
    branch_id [name: 'audit_branch_idx']
    (created_at, action) [name: 'audit_created_action_idx']
  }
}

table branch_inventory {
  id serial [pk, not null, increment]
  branch_id integer [not null]
  organization_id integer [not null]
  organization_inventory_id integer [not null]
  assigned_by_user_id uuid [not null]
  is_visible boolean [not null, default: true]
  is_active boolean [not null, default: true]
  assigned_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]
  deleted_at "timestamp with time zone"

  indexes {
    (branch_id, organization_inventory_id) [name: 'branch_inventory_branch_org_inventory_uq', unique]
    branch_id [name: 'branch_inventory_branch_idx']
    organization_id [name: 'branch_inventory_org_idx']
    organization_inventory_id [name: 'branch_inventory_org_inventory_idx']
    assigned_by_user_id [name: 'branch_inventory_assigned_by_idx']
    is_visible [name: 'branch_inventory_visible_idx']
    is_active [name: 'branch_inventory_active_idx']
    deleted_at [name: 'branch_inventory_deleted_at_idx']
    (branch_id, is_visible, is_active) [name: 'branch_inventory_status_idx']
  }
}

table branch_products {
  id serial [pk, not null, increment]
  branch_id integer [not null]
  organization_id integer [not null]
  global_product_id integer [not null]
  organization_product_id integer
  is_visible boolean [not null, default: true]
  is_available boolean [not null, default: true]
  custom_notes text
  metadata jsonb [default: `{}`]
  updated_by_user_id uuid
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    (branch_id, global_product_id) [name: 'branch_products_branch_product_uq', unique]
    branch_id [name: 'branch_products_branch_idx']
    organization_id [name: 'branch_products_org_idx']
    global_product_id [name: 'branch_products_global_idx']
    organization_product_id [name: 'branch_products_org_product_idx']
    is_visible [name: 'branch_products_visible_idx']
    is_available [name: 'branch_products_available_idx']
  }
}

table branches {
  id serial [pk, not null, increment]
  organization_id integer [not null]
  name varchar(255) [not null]
  admin_user_id uuid
  code varchar(64)
  status varchar(32) [default: 'active']
  group_id integer
  baseline_budget_cents bigint [not null, default: 0]
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    organization_id [name: 'branches_org_idx']
    name [name: 'branches_name_idx']
    status [name: 'branches_status_idx']
    group_id [name: 'branches_group_idx']
  }
}

table budget_addons {
  id serial [pk, not null, increment]
  budget_id integer [not null]
  amount_cents bigint [not null]
  reason text
  created_by_user_id uuid
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    budget_id [name: 'budget_addons_budget_idx']
  }
}

table budgets {
  id serial [pk, not null, increment]
  organization_id integer [not null]
  branch_id integer [not null]
  period varchar(16) [not null]
  amount_allocated_cents bigint [not null, default: 0]
  amount_spent_cents bigint [not null, default: 0]
  amount_held_cents bigint [not null, default: 0]
  amount_credited_cents bigint [not null, default: 0]
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    (branch_id, period) [name: 'budgets_branch_period_uq', unique]
    organization_id [name: 'budgets_org_idx']
    branch_id [name: 'budgets_branch_idx']
  }
}

table categories {
  id serial [pk, not null, increment]
  organization_id integer
  name varchar(255) [not null]
  parent_id integer
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    name [name: 'categories_name_idx']
    organization_id [name: 'categories_org_idx']
  }
}

table employee_credentials {
  id serial [pk, not null, increment]
  branch_id integer [not null]
  organization_id integer [not null]
  username varchar(255)
  email varchar(255) [not null]
  password_hash varchar(255) [not null]
  first_name varchar(128)
  last_name varchar(128)
  mfa_enabled boolean [not null, default: false]
  mfa_secret varchar(255)
  is_active boolean [not null, default: true]
  created_by_user_id uuid [not null]
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]
  deactivated_at "timestamp with time zone"
  session_version integer [not null, default: 1]

  indexes {
    username [name: 'employee_creds_username_uq', unique]
    email [name: 'employee_creds_email_uq']
    branch_id [name: 'employee_creds_branch_idx']
    organization_id [name: 'employee_creds_org_idx']
    is_active [name: 'employee_creds_active_idx']
    created_by_user_id [name: 'employee_creds_created_by_idx']
  }
}

table global_products {
  id serial [pk, not null, increment]
  product_code varchar(128) [not null]
  name varchar(255) [not null]
  description text
  category_id integer
  image_url text
  base_price_cents integer [not null, default: 0]
  discount_type varchar(16)
  discount_value_cents integer
  discount_start_at "timestamp with time zone"
  discount_end_at "timestamp with time zone"
  discount_active boolean [default: false]
  unit varchar(64) [not null, default: 'unit']
  status varchar(32) [not null, default: 'active']
  stock_quantity integer [not null, default: 0]
  metadata jsonb [default: `{}`]
  created_by_user_id uuid
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]
  last_synced_at "timestamp with time zone"
  deleted_at "timestamp with time zone"

  indexes {
    product_code [name: 'global_products_code_idx']
    name [name: 'global_products_name_idx']
    category_id [name: 'global_products_category_idx']
    status [name: 'global_products_status_idx']
    (category_id, status) [name: 'global_products_cat_status_idx']
    (status, created_at) [name: 'global_products_status_created_idx']
  }
}

table group_audit_logs {
  id serial [pk, not null, increment]
  organization_id integer [not null]
  group_id integer
  action varchar(128) [not null]
  performed_by_user_id uuid [not null]
  performed_by_role varchar(64) [not null]
  metadata jsonb [default: `{}`]
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    organization_id [name: 'group_audit_org_idx']
    group_id [name: 'group_audit_group_idx']
    action [name: 'group_audit_action_idx']
    performed_by_user_id [name: 'group_audit_user_idx']
    created_at [name: 'group_audit_timestamp_idx']
  }
}

table groups {
  id serial [pk, not null, increment]
  organization_id integer [not null]
  name varchar(255) [not null]
  description text
  status varchar(32) [default: 'active']
  created_by_user_id uuid [not null]
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    organization_id [name: 'groups_org_idx']
    name [name: 'groups_name_idx']
    status [name: 'groups_status_idx']
  }
}

table head_offices {
  id serial [pk, not null, increment]
  organization_id integer [not null]
  name varchar(255) [not null]
  contact_email varchar(255)
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    organization_id [name: 'head_offices_org_idx']
  }
}

table inventory {
  id serial [pk, not null, increment]
  organization_id integer
  branch_id integer [not null]
  sku_id integer [not null]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    (branch_id, sku_id) [name: 'inventory_branch_sku_uq', unique]
    branch_id [name: 'inventory_branch_idx']
    organization_id [name: 'inventory_org_idx']
    (organization_id, branch_id, sku_id) [name: 'inventory_org_branch_sku_idx']
  }
}

table inventory_sync_logs {
  id serial [pk, not null, increment]
  sync_type varchar(64) [not null]
  trigger_level varchar(32) [not null]
  target_type varchar(32) [not null]
  target_id integer
  affected_products jsonb [default: `[]`]
  changes_count integer [not null, default: 0]
  status varchar(32) [not null, default: 'pending']
  error_message text
  performed_by_user_id uuid [not null]
  started_at "timestamp with time zone" [default: `now()`]
  completed_at "timestamp with time zone"
  metadata jsonb [default: `{}`]

  indexes {
    sync_type [name: 'inventory_sync_logs_type_idx']
    (target_type, target_id) [name: 'inventory_sync_logs_target_idx']
    status [name: 'inventory_sync_logs_status_idx']
    performed_by_user_id [name: 'inventory_sync_logs_user_idx']
    started_at [name: 'inventory_sync_logs_started_at_idx']
  }
}

table mfa_codes {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  code varchar(6) [not null]
  type varchar(20) [not null]
  expires_at "timestamp with time zone" [not null]
  attempts integer [not null, default: 0]
  is_used boolean [not null, default: false]
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    user_id [name: 'mfa_codes_user_idx']
    code [name: 'mfa_codes_code_idx']
    expires_at [name: 'mfa_codes_expires_idx']
    type [name: 'mfa_codes_type_idx']
  }
}

table modifiers {
  id serial [pk, not null, increment]
  name varchar(255) [not null]
  description text
  type varchar(64) [not null, default: 'unit']
  status varchar(32) [not null, default: 'active']
  created_by_user_id uuid
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    name [name: 'modifiers_name_idx']
    type [name: 'modifiers_type_idx']
    status [name: 'modifiers_status_idx']
    created_by_user_id [name: 'modifiers_user_idx']
  }
}

table notifications {
  id serial [pk, not null, increment]
  user_id uuid [not null]
  organization_id integer
  branch_id integer
  type varchar(64) [not null]
  target_role varchar(64)
  message text [not null]
  read_at "timestamp with time zone"
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    user_id [name: 'notifications_user_idx']
    type [name: 'notifications_type_idx']
    organization_id [name: 'notifications_org_idx']
    branch_id [name: 'notifications_branch_idx']
  }
}

table order_items {
  id serial [pk, not null, increment]
  organization_id integer
  order_id integer [not null]
  global_product_id integer [not null]
  product_name varchar(255) [not null]
  product_code varchar(128)
  unit varchar(64) [not null]
  quantity integer [not null]
  price_cents bigint [not null]
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    order_id [name: 'order_items_order_idx']
    organization_id [name: 'order_items_org_idx']
    global_product_id [name: 'order_items_product_idx']
    (global_product_id, order_id) [name: 'order_items_product_order_idx']
  }
}

table orders {
  id serial [pk, not null, increment]
  tid varchar(26) [not null, unique]
  organization_id integer
  branch_id integer [not null]
  status varchar(32) [not null, default: 'PENDING']
  subtotal_cents bigint [not null, default: 0]
  tax_cents bigint [not null, default: 0]
  total_cents bigint [not null, default: 0]
  notes text
  created_by_user_id uuid [not null]
  created_at "timestamp with time zone" [default: `now()`]
  fulfilled_at "timestamp with time zone"
  updated_at "timestamp with time zone" [default: `now()`]
  approved_by_user_id uuid
  approved_at "timestamp with time zone"
  rejected_by_user_id uuid
  rejected_at "timestamp with time zone"
  rejection_reason text
  approval_token varchar(16)
  approval_token_hash varchar(255)
  approval_token_created_at "timestamp with time zone"
  fulfilled_by_user_id uuid
  refunded_at "timestamp with time zone"
  refunded_by_user_id uuid
  status_at_refund varchar(32)
  refund_amount_cents bigint
  refund_reason text
  receipt_data jsonb

  indexes {
    tid [name: 'orders_tid_idx', unique]
    branch_id [name: 'orders_branch_idx']
    status [name: 'orders_status_idx']
    created_at [name: 'orders_created_idx']
    organization_id [name: 'orders_org_idx']
    (organization_id, branch_id, status) [name: 'orders_org_branch_status_idx']
    (branch_id, status, created_at) [name: 'orders_branch_status_created_idx']
    (organization_id, created_at) [name: 'orders_org_created_idx']
  }
}

table org_metrics {
  id serial [pk, not null, increment]
  organization_id integer
  month varchar(16)
  total_orders integer
  total_spend_cents integer
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    organization_id [name: 'org_metrics_org_idx']
  }
}

table organization_inventory {
  id serial [pk, not null, increment]
  organization_id integer [not null]
  global_product_id integer [not null]
  assigned_by_user_id uuid [not null]
  is_active boolean [not null, default: true]
  custom_name varchar(255)
  custom_price_cents integer
  custom_description text
  custom_image_url text
  assigned_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]
  deleted_at "timestamp with time zone"

  indexes {
    (organization_id, global_product_id) [name: 'org_inventory_org_product_uq', unique]
    organization_id [name: 'org_inventory_org_idx']
    global_product_id [name: 'org_inventory_global_product_idx']
    assigned_by_user_id [name: 'org_inventory_assigned_by_idx']
    is_active [name: 'org_inventory_active_idx']
    deleted_at [name: 'org_inventory_deleted_at_idx']
  }
}

table organization_products {
  id serial [pk, not null, increment]
  organization_id integer [not null]
  global_product_id integer [not null]
  is_enabled boolean [not null, default: true]
  custom_name varchar(255)
  custom_description text
  custom_price_cents integer
  custom_image_url text
  tags jsonb [default: `[]`]
  priority integer [default: 0]
  override_level varchar(32) [default: 'super_admin']
  metadata jsonb [default: `{}`]
  updated_by_user_id uuid
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    (organization_id, global_product_id) [name: 'org_products_org_product_uq', unique]
    organization_id [name: 'org_products_org_idx']
    global_product_id [name: 'org_products_global_idx']
    is_enabled [name: 'org_products_enabled_idx']
  }
}

table organization_settings {
  id serial [pk, not null, increment]
  organization_id integer [not null]
  key varchar(128) [not null]
  value jsonb
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    organization_id [name: 'org_settings_org_idx']
  }
}

table organizations {
  id serial [pk, not null, increment]
  name varchar(255) [not null]
  code varchar(64)
  status varchar(32) [default: 'active']
  logo_url varchar(512)
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    name [name: 'org_name_idx', unique]
    code [name: 'org_code_idx', unique]
    status [name: 'org_status_idx']
  }
}

table product_assignments {
  id serial [pk, not null, increment]
  global_product_id integer [not null]
  assigned_to_type varchar(32) [not null]
  assigned_to_id integer [not null]
  action varchar(32) [not null]
  performed_by_user_id uuid [not null]
  performed_by_role varchar(64) [not null]
  metadata jsonb [default: `{}`]
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    global_product_id [name: 'product_assignments_product_idx']
    (assigned_to_type, assigned_to_id) [name: 'product_assignments_assigned_to_idx']
    performed_by_user_id [name: 'product_assignments_user_idx']
  }
}

table product_import_batches {
  id serial [pk, not null, increment]
  file_name varchar(255) [not null]
  uploaded_by_user_id uuid [not null]
  total_rows integer [not null, default: 0]
  successful_rows integer [not null, default: 0]
  failed_rows integer [not null, default: 0]
  status varchar(32) [not null, default: 'processing']
  validation_errors jsonb [default: `[]`]
  imported_product_ids jsonb [default: `[]`]
  metadata jsonb [default: `{}`]
  created_at "timestamp with time zone" [default: `now()`]
  completed_at "timestamp with time zone"

  indexes {
    uploaded_by_user_id [name: 'product_import_batches_user_idx']
    status [name: 'product_import_batches_status_idx']
    created_at [name: 'product_import_batches_created_at_idx']
  }
}

table product_modifiers {
  id serial [pk, not null, increment]
  product_id integer [not null]
  modifier_id integer [not null]
  is_default boolean [not null, default: false]
  sort_order integer [not null, default: 0]
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    product_id [name: 'product_modifiers_product_idx']
    modifier_id [name: 'product_modifiers_modifier_idx']
    (product_id, modifier_id) [name: 'product_modifiers_product_modifier_idx', unique]
  }
}

table products {
  id serial [pk, not null, increment]
  organization_id integer
  name varchar(255) [not null]
  category_id integer [not null]
  description text
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    category_id [name: 'products_category_idx']
    name [name: 'products_name_idx']
    organization_id [name: 'products_org_idx']
  }
}

table refund_items {
  id serial [pk, not null, increment]
  refund_id integer [not null]
  order_item_id integer [not null]
  quantity integer [not null]
  amount_cents bigint [not null]
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    refund_id [name: 'refund_items_refund_idx']
    order_item_id [name: 'refund_items_order_item_idx']
  }
}

table refunds {
  id serial [pk, not null, increment]
  organization_id integer
  order_id integer [not null]
  amount_cents bigint [not null]
  reason varchar(255)
  status varchar(16) [not null, default: 'PENDING']
  requested_by_user_id uuid
  processed_by_user_id uuid
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    order_id [name: 'refunds_order_idx']
    organization_id [name: 'refunds_org_idx']
    processed_by_user_id [name: 'refunds_processed_by_idx']
  }
}

table restock_requests {
  id serial [pk, not null, increment]
  branch_id integer [not null]
  organization_id integer [not null]
  global_product_id integer [not null]
  requested_quantity integer [not null]
  current_stock integer [not null]
  reason text
  status varchar(32) [not null, default: 'pending']
  requested_by_user_id uuid [not null]
  reviewed_by_user_id uuid
  reviewed_at "timestamp with time zone"
  review_notes text
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    branch_id [name: 'restock_requests_branch_idx']
    organization_id [name: 'restock_requests_org_idx']
    global_product_id [name: 'restock_requests_product_idx']
    status [name: 'restock_requests_status_idx']
    requested_by_user_id [name: 'restock_requests_requested_by_idx']
  }
}

table role_permissions {
  id serial [pk, not null, increment]
  role_id integer [not null]
  permission_key varchar(128) [not null]
  allowed boolean [not null, default: true]
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    role_id [name: 'role_permissions_role_idx']
  }
}

table roles {
  id serial [pk, not null, increment]
  name varchar(64) [not null]
  description text
  permissions jsonb [default: `{}`]
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    name [name: 'roles_name_idx', unique]
  }
}

table scheduled_reports {
  id serial [pk, not null, increment]
  organization_id integer
  user_id uuid [not null]
  report_name varchar(255) [not null]
  frequency varchar(32) [not null]
  format varchar(16) [not null]
  emails jsonb [not null, default: `[]`]
  enabled boolean [not null, default: true]
  last_executed_at "timestamp with time zone"
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    user_id [name: 'scheduled_reports_user_idx']
    organization_id [name: 'scheduled_reports_org_idx']
    enabled [name: 'scheduled_reports_enabled_idx']
  }
}

table sessions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  organization_id integer
  refresh_token_hash varchar(255) [not null]
  ip_address varchar(64)
  user_agent varchar(255)
  last_activity_at "timestamp with time zone" [default: `now()`]
  expires_at "timestamp with time zone" [not null]
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    user_id [name: 'sessions_user_idx']
    expires_at [name: 'sessions_expires_idx']
    organization_id [name: 'sessions_org_idx']
  }
}

table skus {
  id serial [pk, not null, increment]
  organization_id integer
  product_id integer [not null]
  sku varchar(128) [not null]
  unit varchar(64) [not null]
  price_cents integer [not null, default: 0]
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    product_id [name: 'skus_product_idx']
    sku [name: 'skus_sku_idx', unique]
    organization_id [name: 'skus_org_idx']
  }
}

table suppliers {
  id serial [pk, not null, increment]
  organization_id integer [not null]
  branch_id integer [not null]
  name varchar(255) [not null]
  address text
  contact varchar(255)
  email varchar(255)
  description text
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]

  indexes {
    organization_id [name: 'suppliers_org_idx']
    branch_id [name: 'suppliers_branch_idx']
    name [name: 'suppliers_name_idx']
  }
}

table system_logs {
  id serial [pk, not null, increment]
  timestamp "timestamp with time zone" [not null, default: `now()`]
  user_id varchar(255)
  user_role varchar(64)
  user_email varchar(255)
  organization_id integer
  branch_id integer
  action varchar(128) [not null]
  resource_type varchar(64) [not null]
  resource_id varchar(128)
  details jsonb
  ip_address varchar(64)
  user_agent text
  success boolean [not null, default: true]
  error_message text
  created_at "timestamp with time zone" [default: `now()`]

  indexes {
    user_id [name: 'system_logs_user_idx']
    action [name: 'system_logs_action_idx']
    (resource_type, resource_id) [name: 'system_logs_resource_idx']
    timestamp [name: 'system_logs_timestamp_idx']
    organization_id [name: 'system_logs_org_idx']
    branch_id [name: 'system_logs_branch_idx']
    user_role [name: 'system_logs_role_idx']
  }
}

table users {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  email varchar(255) [not null]
  username varchar(255)
  password_hash varchar(255) [not null]
  role_id integer [not null]
  is_active boolean [not null, default: true]
  full_name varchar(255)
  first_name varchar(100)
  last_name varchar(100)
  phone varchar(32)
  employee_id varchar(64)
  mfa_enabled boolean [not null, default: false]
  organization_id integer
  branch_id integer
  imprest_holder varchar(255)
  contact_person varchar(255)
  location varchar(255)
  address text
  created_at "timestamp with time zone" [default: `now()`]
  updated_at "timestamp with time zone" [default: `now()`]
  deleted_at "timestamp with time zone"
  session_version integer [not null, default: 1]

  indexes {
    username [name: 'users_username_idx', unique]
    email [name: 'users_email_idx']
    role_id [name: 'users_role_idx']
    is_active [name: 'users_active_idx']
    organization_id [name: 'users_org_idx']
    branch_id [name: 'users_branch_idx']
    employee_id [name: 'users_employee_id_idx']
  }
}

