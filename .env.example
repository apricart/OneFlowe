# Runtime - required in development, test, staging, and production
# Use different secret values in every environment.
DATABASE_URL=
NEXTAUTH_URL=
NEXTAUTH_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CRON_SECRET=

# Runtime - optional tuning
PGPOOL_MAX=
PGPOOL_IDLE_MS=
PGPOOL_CONN_TIMEOUT_MS=
PG_STATEMENT_TIMEOUT_MS=
BCRYPT_ROUNDS=
INACTIVITY_TIMEOUT_MINUTES=
SESSION_VALIDATION_CACHE_TTL_SECONDS=
RATE_LIMIT_TRUST_PROXY_HOPS=
ORDER_TOKEN_ADMIN_EMAIL=

# Runtime - optional AWS SES integration
# Use an IAM workload identity, AWS SSO, or a local AWS profile for credentials.
AWS_REGION=
SES_FROM_EMAIL=
SES_CONFIGURATION_SET=

# Migration tooling only - never configure this on the application runtime
MIGRATION_DATABASE_URL=

# One-time administrator bootstrap only - remove immediately after use
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
